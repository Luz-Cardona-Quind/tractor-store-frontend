{
  "name": "ts-design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ts-design-system/src",
  "prefix": "ts",
  "projectType": "library",
  "tags": ["scope:shared"],
  "targets": {
    "build-elements": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/ts-design-system/elements",
        "browser": "packages/ts-design-system/src/elements.ts",
        "tsConfig": "packages/ts-design-system/tsconfig.lib.json",
        "styles": ["packages/design-tokens/src/lib/index.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["packages/design-tokens/src/lib"]
        },
        "index": false,
        "optimization": false,
        "sourceMap": true
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/ts-design-system/jest.config.cts",
        "tsConfig": "packages/ts-design-system/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 6006,
        "configDir": "packages/ts-design-system/.storybook",
        "compodoc": false,
        "styles": ["packages/design-tokens/src/lib/index.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["packages/design-tokens/src/lib"]
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/ts-design-system",
        "configDir": "packages/ts-design-system/.storybook",
        "compodoc": false,
        "styles": ["packages/design-tokens/src/lib/index.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["packages/design-tokens/src/lib"]
        }
      }
    }
  }
}
